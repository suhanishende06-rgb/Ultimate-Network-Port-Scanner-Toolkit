<!DOCTYPE html>
<html>
<head>
    <title>CyberScope - Web Port Scanner</title>
    <style>
        body {
            background-color: #0e1117;
            color: white;
            font-family: Arial;
            text-align: center;
            padding-top: 50px;
        }
        input {
            padding: 8px;
            margin: 5px;
            border-radius: 5px;
            border: none;
        }
        button {
            padding: 8px 15px;
            border: none;
            background-color: #00ffcc;
            cursor: pointer;
            font-weight: bold;
        }
        .result {
            margin-top: 20px;
            color: lightgreen;
        }
    </style>
</head>
<body>

    <h1>🌐 CyberScope Web Port Scanner</h1>

    <form method="POST">
        <input type="text" name="target" placeholder="Enter IP or Domain" required><br>
        <input type="number" name="start_port" placeholder="Start Port" required>
        <input type="number" name="end_port" placeholder="End Port" required><br>
        <button type="submit">Scan</button>
    </form>

    <div class="result">
        {% for result in results %}
            <p>{{ result }}</p>
        {% endfor %}
    </div>

</body>
</html>
